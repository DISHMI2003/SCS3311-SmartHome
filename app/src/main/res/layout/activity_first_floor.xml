<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/floor_screen_background"
    android:orientation="vertical">

    <!-- Header -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="82dp"
        android:background="@drawable/floor_header_background"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingEnd="18dp">

        <TextView
            android:id="@+id/btnBackFirstFloor"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:gravity="center"
            android:text="‹"
            android:textColor="#E8EDFA"
            android:textSize="38sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="First Floor"
                android:textColor="#F2F5FF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Master Bedroom • Bedroom • Bathroom"
                android:textColor="#8F9CB1"
                android:textSize="12sp" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvFirstFloorStatus"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/floor_online_badge_background"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="● Online"
            android:textColor="#68E9A0"
            android:textSize="11sp"
            android:textStyle="bold" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="22dp"
            android:paddingEnd="18dp"
            android:paddingBottom="28dp">

            <!-- Floor summary -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:background="@drawable/floor_summary_background"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvFirstFloorRoomCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3"
                        android:textColor="#6DE4F1"
                        android:textSize="25sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="ROOMS"
                        android:textColor="#9CA9BC"
                        android:textSize="11sp" />

                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="55dp"
                    android:background="#30405A" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvFirstFloorDeviceCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12"
                        android:textColor="#6DE4F1"
                        android:textSize="25sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="DEVICES"
                        android:textColor="#9CA9BC"
                        android:textSize="11sp" />

                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="55dp"
                    android:background="#30405A" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvFirstFloorActiveCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5"
                        android:textColor="#FFD36F"
                        android:textSize="25sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="ACTIVE"
                        android:textColor="#9CA9BC"
                        android:textSize="11sp" />

                </LinearLayout>

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="Floor Layout"
                android:textColor="#EDF1FF"
                android:textSize="21sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Select a room to manage its devices."
                android:textColor="#8E9BB0"
                android:textSize="13sp" />

            <!-- Master Bedroom -->

            <LinearLayout
                android:id="@+id/cardMasterBedroom"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/room_card_background"
                android:clickable="true"
                android:elevation="5dp"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:background="@drawable/master_bedroom_icon_background"
                        android:gravity="center"
                        android:text="M"
                        android:textColor="#C5BCFF"
                        android:textSize="21sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="15dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Master Bedroom"
                            android:textColor="#F0F3FF"
                            android:textSize="19sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="5 devices • 2 currently ON"
                            android:textColor="#69DFED"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="#9AA8BB"
                        android:textSize="34sp" />

                </LinearLayout>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_marginTop="22dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@drawable/device_chip_background"
                            android:gravity="center"
                            android:paddingStart="13dp"
                            android:paddingEnd="13dp"
                            android:text="Lights"
                            android:textColor="#BCC6D8"
                            android:textSize="11sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_marginStart="9dp"
                            android:background="@drawable/device_chip_background"
                            android:gravity="center"
                            android:paddingStart="13dp"
                            android:paddingEnd="13dp"
                            android:text="Fan"
                            android:textColor="#BCC6D8"
                            android:textSize="11sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_marginStart="9dp"
                            android:background="@drawable/device_chip_background"
                            android:gravity="center"
                            android:paddingStart="13dp"
                            android:paddingEnd="13dp"
                            android:text="AC Outlet"
                            android:textColor="#BCC6D8"
                            android:textSize="11sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_marginStart="9dp"
                            android:background="@drawable/device_chip_background"
                            android:gravity="center"
                            android:paddingStart="13dp"
                            android:paddingEnd="13dp"
                            android:text="Switch Board"
                            android:textColor="#BCC6D8"
                            android:textSize="11sp" />

                    </LinearLayout>

                </HorizontalScrollView>

            </LinearLayout>

            <!-- Bedroom -->

            <LinearLayout
                android:id="@+id/cardBedroom"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/room_card_background"
                android:clickable="true"
                android:elevation="5dp"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:background="@drawable/bedroom_icon_background"
                        android:gravity="center"
                        android:text="B"
                        android:textColor="#72E5F2"
                        android:textSize="21sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="15dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bedroom"
                            android:textColor="#F0F3FF"
                            android:textSize="19sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="4 devices • 2 currently ON"
                            android:textColor="#69DFED"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="#9AA8BB"
                        android:textSize="34sp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_marginTop="22dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:background="@drawable/device_chip_background"
                        android:gravity="center"
                        android:paddingStart="13dp"
                        android:paddingEnd="13dp"
                        android:text="Main Light"
                        android:textColor="#BCC6D8"
                        android:textSize="11sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_marginStart="9dp"
                        android:background="@drawable/device_chip_background"
                        android:gravity="center"
                        android:paddingStart="13dp"
                        android:paddingEnd="13dp"
                        android:text="Night Light"
                        android:textColor="#BCC6D8"
                        android:textSize="11sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_marginStart="9dp"
                        android:background="@drawable/device_chip_background"
                        android:gravity="center"
                        android:paddingStart="13dp"
                        android:paddingEnd="13dp"
                        android:text="Fan"
                        android:textColor="#BCC6D8"
                        android:textSize="11sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Bathroom -->

            <LinearLayout
                android:id="@+id/cardBathroom"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/room_card_background"
                android:clickable="true"
                android:elevation="5dp"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="54dp"
                        android:layout_height="54dp"
                        android:background="@drawable/bathroom_icon_background"
                        android:gravity="center"
                        android:text="W"
                        android:textColor="#7DE5F0"
                        android:textSize="21sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="15dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bathroom"
                            android:textColor="#F0F3FF"
                            android:textSize="19sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="3 devices • 1 currently ON"
                            android:textColor="#69DFED"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textColor="#9AA8BB"
                        android:textSize="34sp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_marginTop="22dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:background="@drawable/device_chip_background"
                        android:gravity="center"
                        android:paddingStart="13dp"
                        android:paddingEnd="13dp"
                        android:text="Light"
                        android:textColor="#BCC6D8"
                        android:textSize="11sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_marginStart="9dp"
                        android:background="@drawable/device_chip_background"
                        android:gravity="center"
                        android:paddingStart="13dp"
                        android:paddingEnd="13dp"
                        android:text="Water Heater"
                        android:textColor="#BCC6D8"
                        android:textSize="11sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_marginStart="9dp"
                        android:background="@drawable/device_chip_background"
                        android:gravity="center"
                        android:paddingStart="13dp"
                        android:paddingEnd="13dp"
                        android:text="Exhaust Fan"
                        android:textColor="#BCC6D8"
                        android:textSize="11sp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>