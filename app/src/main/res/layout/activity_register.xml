<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/register_screen_background"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="26dp"
        android:paddingEnd="18dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/tvRegisterLogo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⌂"
            android:textColor="#6CE7F6"
            android:textSize="54sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Join Pawani"
            android:textColor="#EAF0FF"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="Secure your home with the next generation of smart technology."
            android:textColor="#A8B4C7"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="@drawable/register_card_background"
            android:elevation="8dp"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="24dp"
            android:paddingEnd="22dp"
            android:paddingBottom="24dp">

            <!-- Full name -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Full Name"
                android:textColor="#D3DBEA"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etFullName"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/register_input_background"
                android:hint="ABC Pawani"
                android:importantForAutofill="yes"
                android:inputType="textPersonName"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:singleLine="true"
                android:textColor="#15213B"
                android:textColorHint="#98A4B7"
                android:textSize="15sp" />

            <!-- Email -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Email Address"
                android:textColor="#D3DBEA"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etRegisterEmail"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/register_input_background"
                android:hint="name@example.com"
                android:importantForAutofill="yes"
                android:inputType="textEmailAddress"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:singleLine="true"
                android:textColor="#15213B"
                android:textColorHint="#98A4B7"
                android:textSize="15sp" />

            <!-- Password -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Password"
                android:textColor="#D3DBEA"
                android:textSize="13sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/register_input_background"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="6dp"
                android:paddingEnd="4dp">

                <EditText
                    android:id="@+id/etRegisterPassword"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="Enter password"
                    android:importantForAutofill="yes"
                    android:inputType="textPassword"
                    android:paddingStart="10dp"
                    android:paddingEnd="8dp"
                    android:singleLine="true"
                    android:textColor="#15213B"
                    android:textColorHint="#98A4B7"
                    android:textSize="15sp" />

                <ImageButton
                    android:id="@+id/btnShowRegisterPassword"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Show password"
                    android:padding="12dp"
                    android:src="@android:drawable/ic_menu_view"
                    android:tint="#6D7890" />

            </LinearLayout>

            <!-- Confirm password -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Confirm Password"
                android:textColor="#D3DBEA"
                android:textSize="13sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/register_input_background"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="6dp"
                android:paddingEnd="4dp">

                <EditText
                    android:id="@+id/etConfirmPassword"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="Confirm password"
                    android:importantForAutofill="yes"
                    android:inputType="textPassword"
                    android:paddingStart="10dp"
                    android:paddingEnd="8dp"
                    android:singleLine="true"
                    android:textColor="#15213B"
                    android:textColorHint="#98A4B7"
                    android:textSize="15sp" />

                <ImageButton
                    android:id="@+id/btnShowConfirmPassword"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Show confirm password"
                    android:padding="12dp"
                    android:src="@android:drawable/ic_menu_view"
                    android:tint="#6D7890" />

            </LinearLayout>

            <!-- Terms -->

            <CheckBox
                android:id="@+id/cbTerms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:buttonTint="#55D8E9"
                android:text="I agree to the Terms of Service and Privacy Policy."
                android:textColor="#B7C2D5"
                android:textSize="12sp" />

            <!-- Create account -->


            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnCreateAccount"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/create_account_button_background"
                android:backgroundTint="@null"
                android:elevation="8dp"
                android:text="Create Account  →"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Login link -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Already have an account? "
                android:textColor="#A7B2C5"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvBackToLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:text="Back to Login"
                android:textColor="#67E0F0"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>





    </LinearLayout>

</ScrollView>